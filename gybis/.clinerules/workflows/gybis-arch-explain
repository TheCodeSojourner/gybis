λ(gybis-arch-explain) ≡ λ(root).

  preflight ≡ ¬initialized(root/architecture.md) ∨ empty(root/architecture.md)
    → "not initialized — run /gybis-arch-init"
    │ ¬∅ → proceed

  read ≡ ∫(root/architecture.md) ∪ {ref | ref ↦ architecture.md}

  vsm ≡ {S5, S4, S3, S2, S1}

  breakdown(layer) ≡
    case layer of
      S5 → Identity:
        principles ≡ {p | p ∈ nonNegotiable}
        impl(p) ≡ p → decision
        violation(d) ≡ ¬compatible(d, principles)

      S4 → Intelligence:
        patterns ≡ {π | π is anticipatedChange}
        extensionPoints ≡ {e | e is extensible}
        adaptation ≡ {m | m is learningMechanism}

      S3 → Control:
        constraints ≡ {c | c enforces resourceLimit}
        policies ≡ {pol | pol handles load ∨ failure}
        qualityGates ≡ {g | g triggers on condition(g)}

      S2 → Coordination:
        subsystems ≡ {s | s is component}
        protocols ≡ {pr | pr governs dataFlow(s_i, s_j)}
        sharedState ≡ σ | consistency ≡ consistencyProtocol(σ)

      S1 → Operations:
        tech ≡ {t | t is deployedTechnology, reason(t) ∈ justification}
        commands ≡ {cmd | cmd is developerExecutable}
        recipes ≡ {build, test, deploy}

  crossLayer ≡
    criticalPaths ≡ seq(layers) where request ∨ event traverses
    │ seams ≡ {split ∨ replace ∨ extend}
    │ invariants ≡ {inv | ∀l ∈ vsm : inv(l) = true}
    │ driftRisk ≡ {l | ∃pressure : erode(l:S5, principles)}

  output ≡ structuredProse(headings)
    ¬technicalSyntax
    ¬λ-expr-in-output
    translate(λ → plainEnglish)

  audience ≡ developer{
    knows: softwareArchitecturePatterns
    knows: ¬thisSystem
  }

  invariants:
    ¬invent ∉ architecture.md
    ¬invent ∉ referencedFiles
    flag(∅ ∨ underdeveloped) → signal
    ¬write → readOnly

λ(compile) ≡ preflight ⊢ read ⊢ breakdown ⊗ crossLayer ⊢ output